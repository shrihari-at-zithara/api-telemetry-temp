# PostgreSQL connection (use one of the following approaches)

# Full connection string (preferred when available)
DATABASE_URL=postgresql://user:password@localhost:5432/zithara

# Or discrete settings (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=zithara
PGUSER=postgres
PGPASSWORD=your_password

# Pool tuning (optional)
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# Logging (optional)
API_TELEMETRY_LOG_LEVEL=info

# Search limits (optional — defaults in src/config/telemetry.config.js)
API_CALL_LOG_QUERY_TIMEOUT_MS=10000
API_TELEMETRY_SEARCH_DEFAULT_LIMIT=50
API_TELEMETRY_SEARCH_MAX_LIMIT=100
API_TELEMETRY_SEARCH_MAX_RANGE_DAYS=31
API_TELEMETRY_SEARCH_MAX_TOTAL_RANGE_DAYS=7
API_TELEMETRY_SEARCH_MAX_SNAPSHOT_LIMIT=25
